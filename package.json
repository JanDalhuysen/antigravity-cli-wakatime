{
  "name": "antigravity-cli-wakatime",
  "version": "1.0.0",
  "description": "WakaTime plugin for Google Antigravity CLI - Track your AI usage, lines of code generated, and time spent prompting AI",
  "bin": {
    "antigravity-cli-wakatime": "bin/antigravity-cli-wakatime.js"
  },
  "scripts": {
    "test": "node --check bin/antigravity-cli-wakatime.js",
    "test:wakatime": "node scripts/test-wakatime.js",
    "status": "node scripts/status.js",
    "status:watch": "node scripts/status.js --watch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JanDalhuysen/antigravity-cli-wakatime.git"
  },
  "keywords": [
    "antigravity",
    "antigravity-cli",
    "wakatime",
    "time-tracking",
    "ai"
  ],
  "author": "JanDalhuysen",
  "license": "BSD-3-Clause",
  "bugs": {
    "url": "https://github.com/JanDalhuysen/antigravity-cli-wakatime/issues"
  },
  "homepage": "https://github.com/JanDalhuysen/antigravity-cli-wakatime#readme",
  "devDependencies": {
    "prettier": "^3.8.4"
  }
}
